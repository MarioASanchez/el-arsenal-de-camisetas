spring.application.name=app
spring.datasource.url=jdbc:mysql://localhost:3306/bd_elarsenaldecamisetas
spring.datasource.username=root
spring.datasource.password=
spring.jpa.hibernate.ddl-auto=update
server.port=8080

# JWT - Generar clave con: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
jwt.secret=
jwt.expiration=86400000

# PayPal Sandbox - https://developer.paypal.com
paypal.client-id=
paypal.client-secret=
paypal.mode=sandbox

# Google Drive - ID de la carpeta (no subir el JSON de la cuenta de servicio)
google.drive.folder-id=
